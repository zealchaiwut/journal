# Copy to .env and adjust. journal_fetch.py loads this file at startup.

# OCR backend: macos (Vision framework, local/free) or claude (not implemented yet)
OCR_BACKEND=macos

# Comma-separated recognition languages for macOS Vision.
# Add th-TH if journaling in Thai (needs recent macOS).
OCR_LANGS=en-US

# Gmail search override (optional). Default:
# from:do-not-reply@amazon.com newer_than:7d -label:journal/processed
#GMAIL_QUERY=

# Render DPI for PDF pages before OCR
#OCR_DPI=300
